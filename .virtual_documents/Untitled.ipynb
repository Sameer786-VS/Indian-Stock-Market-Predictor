print("✅ All libraries loaded successfully!")
print(f"   TensorFlow version : {tf.__version__}")
print(f"   XGBoost version    : {xgb.__version__}")


# ─────────────────────────────────────────────
# 2. CONFIGURATION
# ─────────────────────────────────────────────
TICKER      = "RELIANCE.NS"
START_DATE  = "2018-01-01"
END_DATE    = "2024-12-31"
LOOK_BACK   = 60          # days of history LSTM looks at
TEST_SPLIT  = 0.2         # 20% data for testing
RANDOM_SEED = 42

np.random.seed(RANDOM_SEED)
tf.random.set_seed(RANDOM_SEED)


# ─────────────────────────────────────────────
# 3. DATA FETCHING
# ─────────────────────────────────────────────
def fetch_data(ticker: str, start: str, end: str) -> pd.DataFrame:
    """Download OHLCV data from Yahoo Finance."""
    print(f"\n📥 Downloading data for {ticker} ...")
    df = yf.download(ticker, start=start, end=end, auto_adjust=True)
    df.dropna(inplace=True)

    # Flatten multi-level columns if present
    if isinstance(df.columns, pd.MultiIndex):
        df.columns = df.columns.get_level_values(0)

    print(f"   Rows fetched : {len(df)}")
    print(f"   Date range   : {df.index[0].date()} → {df.index[-1].date()}")
    return df


# ─────────────────────────────────────────────
# 4. FEATURE ENGINEERING
# ─────────────────────────────────────────────
def add_technical_indicators(df: pd.DataFrame) -> pd.DataFrame:
    """Add price-action & technical indicator features."""
    close = df["Close"].squeeze()
    high  = df["High"].squeeze()
    low   = df["Low"].squeeze()
    vol   = df["Volume"].squeeze()

    # ── Trend indicators ──────────────────────
    df["SMA_20"]   = ta.trend.sma_indicator(close, window=20)
    df["SMA_50"]   = ta.trend.sma_indicator(close, window=50)
    df["EMA_20"]   = ta.trend.ema_indicator(close, window=20)
    df["MACD"]     = ta.trend.macd(close)
    df["MACD_sig"] = ta.trend.macd_signal(close)
    df["MACD_diff"]= ta.trend.macd_diff(close)
    df["ADX"]      = ta.trend.adx(high, low, close, window=14)

    # ── Momentum indicators ───────────────────
    df["RSI"]      = ta.momentum.rsi(close, window=14)
    df["Stoch_K"]  = ta.momentum.stoch(high, low, close)
    df["Stoch_D"]  = ta.momentum.stoch_signal(high, low, close)
    df["Williams_R"] = ta.momentum.williams_r(high, low, close)
    df["ROC"]      = ta.momentum.roc(close, window=12)

    # ── Volatility indicators ─────────────────
    bb = ta.volatility.BollingerBands(close, window=20)
    df["BB_upper"] = bb.bollinger_hband()
    df["BB_lower"] = bb.bollinger_lband()
    df["BB_width"] = bb.bollinger_wband()
    df["ATR"]      = ta.volatility.average_true_range(high, low, close)

    # ── Volume indicators ─────────────────────
    df["OBV"]      = ta.volume.on_balance_volume(close, vol)
    df["VWAP"]     = ta.volume.volume_weighted_average_price(high, low, close, vol)

    # ── Price action features ─────────────────
    df["Candle_body"]   = (close - df["Open"]).abs()
    df["Upper_shadow"]  = high - df[["Open", "Close"]].max(axis=1)
    df["Lower_shadow"]  = df[["Open", "Close"]].min(axis=1) - low
    df["Price_change"]  = close.pct_change()
    df["Vol_change"]    = vol.pct_change()
    df["High_Low_pct"]  = (high - low) / low * 100

    # ── Lag features (past N-day closes) ──────
    for lag in [1, 2, 3, 5, 10, 20]:
        df[f"Lag_{lag}"] = close.shift(lag)

    # ── Rolling stats ─────────────────────────
    df["Rolling_std_10"] = close.rolling(10).std()
    df["Rolling_mean_10"]= close.rolling(10).mean()

    # ── TARGET: 1 = price UP tomorrow, 0 = DOWN ──
    df["Target"] = (close.shift(-1) > close).astype(int)

    df.dropna(inplace=True)
    print(f"   Features engineered : {len(df.columns)} columns")
    return df


# ─────────────────────────────────────────────
# 5. XGBOOST MODEL
# ─────────────────────────────────────────────
def train_xgboost(df: pd.DataFrame):
    """Train XGBoost classifier and return results."""
    print("\n" + "="*50)
    print("🌲  XGBOOST MODEL")
    print("="*50)

    feature_cols = [c for c in df.columns
                    if c not in ["Target", "Open", "High", "Low", "Close", "Volume"]]
    X = df[feature_cols].values
    y = df["Target"].values

    split = int(len(X) * (1 - TEST_SPLIT))
    X_train, X_test = X[:split], X[split:]
    y_train, y_test = y[:split], y[split:]

    model = xgb.XGBClassifier(
        n_estimators=300,
        max_depth=6,
        learning_rate=0.05,
        subsample=0.8,
        colsample_bytree=0.8,
        use_label_encoder=False,
        eval_metric="logloss",
        random_state=RANDOM_SEED,
        verbosity=0
    )
    model.fit(X_train, y_train,
              eval_set=[(X_test, y_test)],
              verbose=False)

    y_pred  = model.predict(X_test)
    y_proba = model.predict_proba(X_test)[:, 1]
    acc     = accuracy_score(y_test, y_pred)

    print(f"\n   Test Accuracy : {acc*100:.2f}%")
    print(f"\n{classification_report(y_test, y_pred, target_names=['DOWN','UP'])}")

    # Feature importances
    importances = pd.Series(model.feature_importances_, index=feature_cols)
    top10 = importances.nlargest(10)

    return model, y_test, y_pred, y_proba, top10, acc, feature_cols, split


# ─────────────────────────────────────────────
# 6. LSTM MODEL
# ─────────────────────────────────────────────
def prepare_lstm_sequences(df: pd.DataFrame, look_back: int):
    """Create sliding-window sequences for LSTM."""
    feature_cols = [c for c in df.columns
                    if c not in ["Target", "Open", "High", "Low", "Close", "Volume"]]
    X_raw = df[feature_cols].values
    y_raw = df["Target"].values

    scaler = MinMaxScaler()
    X_scaled = scaler.fit_transform(X_raw)

    X_seq, y_seq = [], []
    for i in range(look_back, len(X_scaled)):
        X_seq.append(X_scaled[i - look_back:i])
        y_seq.append(y_raw[i])

    return np.array(X_seq), np.array(y_seq), scaler, feature_cols


def build_lstm(input_shape):
    """Build LSTM architecture."""
    model = Sequential([
        LSTM(128, return_sequences=True, input_shape=input_shape),
        BatchNormalization(),
        Dropout(0.3),

        LSTM(64, return_sequences=True),
        BatchNormalization(),
        Dropout(0.3),

        LSTM(32, return_sequences=False),
        BatchNormalization(),
        Dropout(0.2),

        Dense(16, activation="relu"),
        Dense(1, activation="sigmoid")
    ])
    model.compile(
        optimizer=Adam(learning_rate=0.001),
        loss="binary_crossentropy",
        metrics=["accuracy"]
    )
    return model


def train_lstm(df: pd.DataFrame):
    """Train LSTM and return results."""
    print("\n" + "="*50)
    print("🧠  LSTM DEEP LEARNING MODEL")
    print("="*50)

    X_seq, y_seq, scaler, feature_cols = prepare_lstm_sequences(df, LOOK_BACK)

    split = int(len(X_seq) * (1 - TEST_SPLIT))
    X_train, X_test = X_seq[:split], X_seq[split:]
    y_train, y_test = y_seq[:split], y_seq[split:]

    print(f"   Train samples : {len(X_train)}")
    print(f"   Test  samples : {len(X_test)}")
    print(f"   Input shape   : {X_train.shape[1:]}")

    model = build_lstm(X_train.shape[1:])
    model.summary()

    callbacks = [
        EarlyStopping(patience=10, restore_best_weights=True, verbose=1),
        ReduceLROnPlateau(factor=0.5, patience=5, verbose=1)
    ]

    history = model.fit(
        X_train, y_train,
        validation_data=(X_test, y_test),
        epochs=80,
        batch_size=32,
        callbacks=callbacks,
        verbose=1
    )

    y_proba = model.predict(X_test, verbose=0).flatten()
    y_pred  = (y_proba > 0.5).astype(int)
    acc     = accuracy_score(y_test, y_pred)

    print(f"\n   Test Accuracy : {acc*100:.2f}%")
    print(f"\n{classification_report(y_test, y_pred, target_names=['DOWN','UP'])}")

    return model, y_test, y_pred, y_proba, history, acc


# ─────────────────────────────────────────────
# 7. BACKTESTING
# ─────────────────────────────────────────────
def backtest(df: pd.DataFrame, predictions: np.ndarray,
             split_idx: int, model_name: str) -> dict:
    """Simple backtest: buy when model predicts UP, sell when DOWN."""
    print(f"\n📈 Backtesting {model_name} ...")

    prices = df["Close"].values.flatten()
    test_prices = prices[split_idx: split_idx + len(predictions)]

    capital         = 100_000  # ₹1,00,000 starting capital
    initial_capital = capital
    position        = 0        # shares held
    portfolio       = []
    buy_and_hold    = []

    bh_shares = capital / test_prices[0]

    for i, pred in enumerate(predictions):
        price = test_prices[i]
        bh_val = bh_shares * price

        if pred == 1 and position == 0:          # BUY signal
            position = capital / price
            capital  = 0
        elif pred == 0 and position > 0:          # SELL signal
            capital  = position * price
            position = 0

        current_val = capital + (position * price)
        portfolio.append(current_val)
        buy_and_hold.append(bh_val)

    # Close final position
    if position > 0:
        capital  = position * test_prices[-1]
        position = 0
    portfolio[-1] = capital

    total_return    = (capital - initial_capital) / initial_capital * 100
    bh_return       = (buy_and_hold[-1] - initial_capital) / initial_capital * 100

    print(f"   {model_name} Return   : {total_return:+.2f}%")
    print(f"   Buy-&-Hold Return : {bh_return:+.2f}%")
    print(f"   Final Capital     : ₹{capital:,.0f}")

    return {
        "model_name"   : model_name,
        "portfolio"    : portfolio,
        "buy_and_hold" : buy_and_hold,
        "total_return" : total_return,
        "bh_return"    : bh_return,
        "test_prices"  : test_prices,
    }


# ─────────────────────────────────────────────
# 8. VISUALISATION
# ─────────────────────────────────────────────
def plot_all(df, xgb_results, lstm_results,
             bt_xgb, bt_lstm, xgb_top10, lstm_history):
    """One large dashboard with all results."""

    plt.style.use("dark_background")
    fig = plt.figure(figsize=(22, 26))
    fig.patch.set_facecolor("#0d1117")

    gs = gridspec.GridSpec(5, 2, figure=fig,
                           hspace=0.55, wspace=0.35,
                           top=0.95, bottom=0.04,
                           left=0.07, right=0.96)

    ACCENT  = "#00d4aa"
    ACCENT2 = "#ff6b6b"
    ACCENT3 = "#ffd93d"
    GRID_C  = "#1e2433"
    TEXT_C  = "#c9d1d9"

    def style_ax(ax, title):
        ax.set_facecolor("#0d1117")
        ax.tick_params(colors=TEXT_C, labelsize=9)
        for spine in ax.spines.values():
            spine.set_edgecolor(GRID_C)
        ax.yaxis.grid(True, color=GRID_C, linewidth=0.5)
        ax.set_title(title, color=ACCENT, fontsize=11,
                     fontweight="bold", pad=10)

    # ─── Row 0: Price + indicator ──────────────────────
    ax0 = fig.add_subplot(gs[0, :])
    close = df["Close"].values.flatten()
    dates = df.index

    ax0.plot(dates, close, color=ACCENT, lw=1.5, label="Close Price")
    ax0.plot(dates, df["SMA_20"].values, color=ACCENT3,
             lw=1, alpha=0.7, label="SMA 20")
    ax0.plot(dates, df["SMA_50"].values, color=ACCENT2,
             lw=1, alpha=0.7, label="SMA 50")
    ax0.fill_between(dates,
                     df["BB_upper"].values,
                     df["BB_lower"].values,
                     alpha=0.08, color=ACCENT, label="Bollinger Bands")
    style_ax(ax0, "RELIANCE.NS — Price Action with Indicators")
    ax0.legend(facecolor="#161b22", edgecolor=GRID_C,
               labelcolor=TEXT_C, fontsize=8)
    ax0.set_ylabel("Price (₹)", color=TEXT_C)

    # ─── Row 1: RSI | MACD ────────────────────────────
    ax1 = fig.add_subplot(gs[1, 0])
    ax1.plot(dates, df["RSI"].values, color=ACCENT3, lw=1.2)
    ax1.axhline(70, color=ACCENT2, lw=0.8, linestyle="--", alpha=0.7)
    ax1.axhline(30, color=ACCENT,  lw=0.8, linestyle="--", alpha=0.7)
    ax1.fill_between(dates, df["RSI"].values, 70,
                     where=(df["RSI"].values >= 70),
                     color=ACCENT2, alpha=0.2)
    ax1.fill_between(dates, df["RSI"].values, 30,
                     where=(df["RSI"].values <= 30),
                     color=ACCENT, alpha=0.2)
    style_ax(ax1, "RSI (14)")
    ax1.set_ylim(0, 100)
    ax1.set_ylabel("RSI", color=TEXT_C)

    ax2 = fig.add_subplot(gs[1, 1])
    macd_diff = df["MACD_diff"].values
    colors_macd = [ACCENT if v >= 0 else ACCENT2 for v in macd_diff]
    ax2.bar(dates, macd_diff, color=colors_macd, width=1.5, alpha=0.8)
    ax2.plot(dates, df["MACD"].values, color=ACCENT3, lw=1, label="MACD")
    ax2.plot(dates, df["MACD_sig"].values, color=ACCENT2, lw=1, label="Signal")
    style_ax(ax2, "MACD")
    ax2.legend(facecolor="#161b22", edgecolor=GRID_C,
               labelcolor=TEXT_C, fontsize=8)

    # ─── Row 2: Confusion matrices ────────────────────
    _, xgb_y_test, xgb_y_pred, _, xgb_top10_, xgb_acc, _, _ = xgb_results
    _, lstm_y_test, lstm_y_pred, _, _, lstm_acc = lstm_results

    for col, (y_t, y_p, name, acc) in enumerate([
        (xgb_y_test,  xgb_y_pred,  "XGBoost", xgb_acc),
        (lstm_y_test, lstm_y_pred, "LSTM",    lstm_acc)
    ]):
        ax = fig.add_subplot(gs[2, col])
        cm = confusion_matrix(y_t, y_p)
        disp = ConfusionMatrixDisplay(cm, display_labels=["DOWN", "UP"])
        disp.plot(ax=ax, colorbar=False,
                  cmap="YlGn" if col == 0 else "PuBu")
        ax.set_facecolor("#0d1117")
        ax.tick_params(colors=TEXT_C, labelsize=9)
        ax.set_title(f"{name} Confusion Matrix  |  Accuracy: {acc*100:.1f}%",
                     color=ACCENT, fontsize=11, fontweight="bold", pad=10)
        ax.xaxis.label.set_color(TEXT_C)
        ax.yaxis.label.set_color(TEXT_C)
        for spine in ax.spines.values():
            spine.set_edgecolor(GRID_C)

    # ─── Row 3: Feature importance | LSTM loss ────────
    ax5 = fig.add_subplot(gs[3, 0])
    bars = ax5.barh(range(len(xgb_top10_)), xgb_top10_.values,
                    color=ACCENT, alpha=0.85)
    ax5.set_yticks(range(len(xgb_top10_)))
    ax5.set_yticklabels(xgb_top10_.index, fontsize=8)
    style_ax(ax5, "XGBoost — Top 10 Feature Importances")
    ax5.set_xlabel("Importance", color=TEXT_C, fontsize=9)

    ax6 = fig.add_subplot(gs[3, 1])
    hist = lstm_results[4]
    epochs_ran = range(1, len(hist.history["loss"]) + 1)
    ax6.plot(epochs_ran, hist.history["loss"],
             color=ACCENT, lw=1.5, label="Train Loss")
    ax6.plot(epochs_ran, hist.history["val_loss"],
             color=ACCENT2, lw=1.5, label="Val Loss")
    style_ax(ax6, "LSTM — Training Loss Curve")
    ax6.set_xlabel("Epoch", color=TEXT_C, fontsize=9)
    ax6.set_ylabel("Loss", color=TEXT_C, fontsize=9)
    ax6.legend(facecolor="#161b22", edgecolor=GRID_C,
               labelcolor=TEXT_C, fontsize=8)

    # ─── Row 4: Backtest comparison ───────────────────
    ax7 = fig.add_subplot(gs[4, :])
    bt_dates_xgb  = range(len(bt_xgb["portfolio"]))
    bt_dates_lstm = range(len(bt_lstm["portfolio"]))

    ax7.plot(bt_dates_xgb, bt_xgb["portfolio"],
             color=ACCENT3, lw=1.8, label=f"XGBoost ({bt_xgb['total_return']:+.1f}%)")
    ax7.plot(bt_dates_lstm, bt_lstm["portfolio"],
             color=ACCENT, lw=1.8, label=f"LSTM ({bt_lstm['total_return']:+.1f}%)")
    ax7.plot(bt_dates_xgb, bt_xgb["buy_and_hold"],
             color=ACCENT2, lw=1.2, linestyle="--",
             label=f"Buy & Hold ({bt_xgb['bh_return']:+.1f}%)")
    ax7.axhline(100_000, color="#555", lw=0.8, linestyle=":")
    style_ax(ax7, "📊  Backtesting  —  Strategy Returns vs Buy & Hold  (₹1,00,000 initial capital)")
    ax7.set_xlabel("Trading Days (Test Period)", color=TEXT_C)
    ax7.set_ylabel("Portfolio Value (₹)", color=TEXT_C)
    ax7.legend(facecolor="#161b22", edgecolor=GRID_C,
               labelcolor=TEXT_C, fontsize=9)

    # ─── Main title ───────────────────────────────────
    fig.suptitle("RELIANCE.NS  ·  Stock Market Predictor Dashboard\n"
                 "XGBoost  vs  LSTM  Deep Learning",
                 color="white", fontsize=16, fontweight="bold", y=0.98)

    plt.savefig("/mnt/user-data/outputs/reliance_predictor_dashboard.png",
                dpi=150, bbox_inches="tight",
                facecolor=fig.get_facecolor())
    print("\n✅ Dashboard saved!")
    plt.close()


# ─────────────────────────────────────────────
# 9. PREDICT NEXT DAY
# ─────────────────────────────────────────────
def predict_next_day(df, xgb_model, lstm_model, feature_cols, scaler):
    """Predict tomorrow's move for RELIANCE.NS."""
    print("\n" + "="*50)
    print("🔮  NEXT DAY PREDICTION")
    print("="*50)

    last_close = float(df["Close"].iloc[-1])
    print(f"   Last closing price : ₹{last_close:,.2f}")

    # XGBoost prediction
    X_last     = df[feature_cols].iloc[-1].values.reshape(1, -1)
    xgb_pred   = xgb_model.predict(X_last)[0]
    xgb_proba  = xgb_model.predict_proba(X_last)[0]

    # LSTM prediction
    X_all_scaled = scaler.transform(df[feature_cols].values)
    X_lstm_last  = X_all_scaled[-LOOK_BACK:].reshape(1, LOOK_BACK, -1)
    lstm_proba_val = float(lstm_model.predict(X_lstm_last, verbose=0)[0][0])
    lstm_pred    = 1 if lstm_proba_val > 0.5 else 0

    direction_map = {1: "📈  UP", 0: "📉  DOWN"}

    print(f"\n   XGBoost  → {direction_map[xgb_pred]}"
          f"  (Confidence: UP={xgb_proba[1]*100:.1f}% | DOWN={xgb_proba[0]*100:.1f}%)")
    print(f"   LSTM     → {direction_map[lstm_pred]}"
          f"  (Confidence: UP={lstm_proba_val*100:.1f}%  | DOWN={(1-lstm_proba_val)*100:.1f}%)")

    # Combined signal
    avg_up = (xgb_proba[1] + lstm_proba_val) / 2
    combined = "📈  UP" if avg_up > 0.5 else "📉  DOWN"
    print(f"\n   🤝 COMBINED SIGNAL → {combined}  (Avg UP confidence: {avg_up*100:.1f}%)")
    print(f"\n   ⚠️  This is educational — NOT financial advice.")


# ─────────────────────────────────────────────
# 10. MAIN PIPELINE
# ─────────────────────────────────────────────
def main():
    # Step 1 — Fetch data
    raw_df = fetch_data(TICKER, START_DATE, END_DATE)

    # Step 2 — Add features
    df = add_technical_indicators(raw_df.copy())

    # Step 3 — XGBoost
    xgb_out = train_xgboost(df)
    (xgb_model, xgb_y_test, xgb_y_pred,
     xgb_y_proba, xgb_top10, xgb_acc, feature_cols, xgb_split) = xgb_out

    # Step 4 — LSTM
    lstm_out = train_lstm(df)
    (lstm_model, lstm_y_test, lstm_y_pred,
     lstm_y_proba, lstm_history, lstm_acc) = lstm_out

    # Step 5 — Backtest
    lstm_split = xgb_split + LOOK_BACK   # offset for sequence length
    bt_xgb  = backtest(df, xgb_y_pred,  xgb_split,  "XGBoost")
    bt_lstm = backtest(df, lstm_y_pred, lstm_split, "LSTM")

    # Step 6 — Build scaler for prediction
    _feature_cols_lst = [c for c in df.columns
                         if c not in ["Target","Open","High","Low","Close","Volume"]]
    scaler = MinMaxScaler()
    scaler.fit(df[_feature_cols_lst].values)

    # Step 7 — Next-day prediction
    predict_next_day(df, xgb_model, lstm_model, feature_cols, scaler)

    # Step 8 — Dashboard
    print("\n🎨 Generating dashboard ...")
    plot_all(df,
             (xgb_model, xgb_y_test, xgb_y_pred,
              xgb_y_proba, xgb_top10, xgb_acc, feature_cols, xgb_split),
             (lstm_model, lstm_y_test, lstm_y_pred,
              lstm_y_proba, lstm_history, lstm_acc),
             bt_xgb, bt_lstm, xgb_top10, lstm_history)

    print("\n🎉  Pipeline complete!")


if __name__ == "__main__":
    main()



